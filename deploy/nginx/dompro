# /etc/nginx/sites-available/dompro
# Nginx: статика frontend + reverse proxy к uvicorn
#
# Установка:
#   sudo cp deploy/nginx/dompro /etc/nginx/sites-available/dompro
#   sudo ln -sf /etc/nginx/sites-available/dompro /etc/nginx/sites-enabled/dompro
#   sudo nginx -t && sudo systemctl reload nginx

# Редирект HTTP → HTTPS (раскомментировать после certbot)
# server {
#     listen 80;
#     listen [::]:80;
#     server_name dompro.ru www.dompro.ru;
#     return 301 https://$host$request_uri;
# }

server {
    listen 80;
    listen [::]:80;
    server_name dompro.ru www.dompro.ru;

    # После certbot: listen 443 ssl; + ssl_certificate / ssl_certificate_key
    # ssl_certificate     /etc/letsencrypt/live/dompro.ru/fullchain.pem;
    # ssl_certificate_key /etc/letsencrypt/live/dompro.ru/privkey.pem;

    root /opt/dompro/frontend;
    index index.html;

    # Загрузка файлов (верификация, договоры)
    client_max_body_size 50M;

    # Gzip
    gzip on;
    gzip_vary on;
    gzip_proxied any;
    gzip_comp_level 5;
    gzip_min_length 256;
    gzip_types
        text/plain
        text/css
        text/javascript
        application/javascript
        application/json
        application/xml
        image/svg+xml;

    # Security headers
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;
    add_header X-XSS-Protection "1; mode=block" always;

    # API → uvicorn
    location /api/ {
        proxy_pass http://127.0.0.1:8000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 120s;
        proxy_connect_timeout 10s;
    }

    # Health / docs (опционально, только для админов — можно закрыть)
    location ~ ^/(health|docs|redoc|openapi\.json)$ {
        proxy_pass http://127.0.0.1:8000;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Статика фронтенда
    location / {
        try_files $uri $uri/ /index.html;
    }

    # Кэш для CSS/JS
    location ~* \.(css|js|png|jpg|jpeg|gif|ico|svg|woff2?)$ {
        expires 7d;
        add_header Cache-Control "public, immutable";
        try_files $uri =404;
    }

    access_log /var/log/nginx/dompro.access.log;
    error_log  /var/log/nginx/dompro.error.log;
}
